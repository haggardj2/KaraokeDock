# Database Configuration
POSTGRES_DB=karaoke
POSTGRES_USER=karaoke
POSTGRES_PASSWORD=karaoke # Change to a strong password
DB_PATH=/home/user/web-karaoke/db # Location for postgres db
DB_PORT=5432 # Host port for db

# Combined app configuration
APP_PORT=5173 # Host port for app
MEDIA_ROOT=/media
KARAOKE_PATH=/mnt/karaoke/Karaoke Tracks
DOWNLOADS_PATH=/mnt/karaoke/downloads
BREAKMUSIC_PATH=/mnt/karaoke/Break Music

# URL for the app
# Change to either host IP, or use a fqdn if using a reverse proxy
# http://192.168.1.20 or https://app.example.com
WEB_APP_URL=http://localhost:5173

# CORS/WebSocket origins for the app
# Change to either host IP, or use a fqdn if using a reverse proxy
# http://192.168.1.20 or https://app.example.com
ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Trust proxy headers when running behind a reverse proxy
TRUST_PROXY=1
